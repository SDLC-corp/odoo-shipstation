<odoo>
    <record id="view_shipstation_sync_log_tree" model="ir.ui.view">
        <field name="name">shipstation.sync.log.tree</field>
        <field name="model">shipstation.sync.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="instance_id"/>
                <field name="status"/>
                <field name="method"/>
                <field name="endpoint"/>
                <field name="error_message"/>
                <field name="retry_count"/>
            </list>
        </field>
    </record>

    <record id="view_shipstation_sync_log_form" model="ir.ui.view">
        <field name="name">shipstation.sync.log.form</field>
        <field name="model">shipstation.sync.log</field>
        <field name="arch" type="xml">
            <form string="ShipStation Sync Log">
                <header>
                    <button name="action_retry_sync" type="object" string="Retry Sync" class="btn-primary" invisible="status != 'failed'"/>
                </header>
                <sheet>
                    <group>
                        <field name="instance_id"/>
                        <field name="operation"/>
                        <field name="model_name"/>
                        <field name="status"/>
                        <field name="method"/>
                        <field name="endpoint"/>
                        <field name="retry_count"/>
                        <field name="last_retry_at"/>
                    </group>
                    <group>
                        <field name="request_payload"/>
                        <field name="response_payload"/>
                        <field name="error_message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
