<odoo>
    <record id="view_shipstation_order_sync_tree" model="ir.ui.view">
        <field name="name">shipstation.order.sync.tree</field>
        <field name="model">shipstation.order.sync</field>
        <field name="arch" type="xml">
            <list>
                <field name="shipstation_order_number"/>
                <field name="customer_name"/>
                <field name="status"/>
                <field name="total_amount"/>
                <field name="order_date"/>
                <field name="synced_on"/>
            </list>
        </field>
    </record>

    <record id="view_shipstation_order_sync_form" model="ir.ui.view">
        <field name="name">shipstation.order.sync.form</field>
        <field name="model">shipstation.order.sync</field>
        <field name="arch" type="xml">
            <form string="ShipStation Order">
                <header>
                    <button name="action_pull_from_shipstation" type="object" string="Pull from ShipStation" class="btn-secondary"/>
                    <button name="action_push_to_shipstation" type="object" string="Push to ShipStation" class="btn-primary"/>
                    <button name="action_get_rates" type="object" string="Get Rates" class="btn-secondary"/>
                    <button name="action_select_best_rate" type="object" string="Select Best Rate" class="btn-secondary"/>
                    <button name="action_create_label" type="object" string="Create Label" class="btn-secondary"/>
                    <button name="action_open_label" type="object" string="Open Label" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="instance_id"/>
                        <field name="shipstation_order_id"/>
                        <field name="shipstation_order_number"/>
                        <field name="shipstation_store_id"/>
                        <field name="status"/>
                        <field name="order_date"/>
                        <field name="last_modified_date"/>
                        <field name="synced_on"/>
                    </group>
                    <group>
                        <field name="customer_name"/>
                        <field name="customer_email"/>
                        <field name="total_amount"/>
                        <field name="currency"/>
                    </group>
                    <group string="Shipping / Label">
                        <field name="carrier_code"/>
                        <field name="service_code"/>
                        <field name="package_code"/>
                        <field name="confirmation"/>
                        <field name="ship_date"/>
                        <field name="tracking_number"/>
                        <field name="tracking_url"/>
                        <field name="label_url"/>
                        <field name="shipstation_shipment_id"/>
                    </group>
                    <group string="Rates">
                        <field name="rate_ids">
                            <list>
                                <field name="carrier_code"/>
                                <field name="service_code"/>
                                <field name="shipment_cost"/>
                                <field name="other_cost"/>
                                <field name="tax_amount"/>
                                <field name="delivery_days"/>
                            </list>
                        </field>
                    </group>
                    <group>
                        <field name="payload"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
