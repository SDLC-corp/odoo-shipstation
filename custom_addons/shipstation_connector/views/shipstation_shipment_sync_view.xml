<odoo>
    <record id="view_shipstation_shipment_sync_tree" model="ir.ui.view">
        <field name="name">shipstation.shipment.sync.tree</field>
        <field name="model">shipstation.shipment.sync</field>
        <field name="arch" type="xml">
            <list>
                <header>
                    <button name="action_open_delivery_order" type="object" string="Open Delivery" class="btn-secondary"/>
                    <button name="action_open_tracking" type="object" string="Open Tracking" class="btn-secondary"/>
                </header>
                <field name="shipstation_order_id"/>
                <field name="shipstation_order_number"/>
                <field name="ship_date"/>
                <field name="status"/>
                <field name="synced_on"/>
            </list>
        </field>
    </record>

    <record id="view_shipstation_shipment_sync_form" model="ir.ui.view">
        <field name="name">shipstation.shipment.sync.form</field>
        <field name="model">shipstation.shipment.sync</field>
        <field name="arch" type="xml">
            <form string="ShipStation Shipment">
                <header>
                    <button name="action_open_delivery_order" type="object" string="Open Delivery" class="btn-secondary"/>
                    <button name="action_open_tracking" type="object" string="Open Tracking" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="instance_id"/>
                        <field name="shipstation_shipment_id"/>
                        <field name="shipstation_order_id"/>
                        <field name="shipstation_order_number"/>
                        <field name="shipstation_store_id"/>
                        <field name="carrier_code"/>
                        <field name="service_code"/>
                        <field name="tracking_number"/>
                        <field name="tracking_url"/>
                        <field name="ship_date"/>
                        <field name="status"/>
                        <field name="synced_on"/>
                    </group>
                    <group>
                        <field name="payload"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
