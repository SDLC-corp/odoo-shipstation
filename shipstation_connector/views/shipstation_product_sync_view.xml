<odoo>
    <record id="view_shipstation_product_sync_tree" model="ir.ui.view">
        <field name="name">shipstation.product.sync.tree</field>
        <field name="model">shipstation.product.sync</field>
        <field name="arch" type="xml">
            <list>
                <field name="sku"/>
                <field name="name"/>
                <field name="price"/>
                <field name="stock_level" string="In Stock"/>
                <field name="modify_date"/>
                <field name="synced_on"/>
            </list>
        </field>
    </record>

    <record id="view_shipstation_product_sync_form" model="ir.ui.view">
        <field name="name">shipstation.product.sync.form</field>
        <field name="model">shipstation.product.sync</field>
        <field name="arch" type="xml">
            <form string="ShipStation Product">
                <header>
                    <button name="action_pull_from_shipstation" type="object" string="Pull from ShipStation" class="btn-secondary"/>
                    <button name="action_push_to_shipstation" type="object" string="Push to ShipStation" class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="instance_id"/>
                        <field name="shipstation_product_id"/>
                        <field name="sku"/>
                        <field name="name"/>
                        <field name="price"/>
                        <field name="weight"/>
                        <field name="stock_level" string="In Stock"/>
                        <field name="modify_date"/>
                        <field name="synced_on"/>
                    </group>
                    <group>
                        <field name="payload"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>
