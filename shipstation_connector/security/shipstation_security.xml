<odoo>
    <record id="group_shipstation_admin" model="res.groups">
        <field name="name">ShipStation Admin</field>
        <field name="category_id" ref="base.module_category_inventory"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_shipstation_manager" model="res.groups">
        <field name="name">ShipStation Manager</field>
        <field name="category_id" ref="base.module_category_inventory"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_shipstation_user_readonly" model="res.groups">
        <field name="name">ShipStation User (Read Only)</field>
        <field name="category_id" ref="base.module_category_inventory"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
